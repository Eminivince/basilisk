# Basilisk environment configuration.
# Copy to `.env` at the workspace root and fill in the keys you need.
# Keys are optional — features that require a specific key will error
# at the point of use, not at startup.

# Anthropic API key — default LLM provider for the agent loop
# (`basilisk recon <target> --agent`).
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key — used when running with `--provider openrouter`.
# Unlocks Claude, GPT, Gemini, Llama, and every other model OpenRouter
# proxies, all via the same key.
# OPENROUTER_API_KEY=sk-or-...

# OpenAI API key — used when running with `--provider openai`. Also
# used as the fallback key for `--provider openai-compat` when no
# `--llm-api-key-env` override is given.
# OPENAI_API_KEY=sk-...

# --- Agent defaults (so `basilisk recon <target> --agent` Just Works) ---
#
# Every BASILISK_* setting below mirrors a CLI flag. The CLI wins when
# both are set, so these are defaults you can override per-invocation.

# Which backend to route through. One of:
#   anthropic (default) | openrouter | openai | ollama | openai-compat
# BASILISK_LLM_PROVIDER=openrouter

# Model id. Meaning depends on provider:
#   anthropic    → claude-opus-4-7, claude-sonnet-4-6, ...
#   openrouter   → anthropic/claude-opus-4-7, openai/gpt-4o, ...
#   openai       → gpt-4o, gpt-4o-mini, ...
#   ollama       → llama3.1:70b, qwen2.5-coder:32b, ...
#   openai-compat → whatever your server exposes
# BASILISK_LLM_MODEL=anthropic/claude-opus-4-7

# Override the API base URL. Only meaningful with --provider
# openai-compat (required) and ollama (optional override of its
# localhost default). Ignored for anthropic/openrouter/openai.
# BASILISK_LLM_BASE_URL=http://localhost:8080/v1

# Override which env var to read the API key from. Defaults per
# provider: ANTHROPIC_API_KEY, OPENROUTER_API_KEY, OPENAI_API_KEY.
# BASILISK_LLM_API_KEY_ENV=MY_CUSTOM_KEY_VAR

# Budget caps. Defaults: 40 turns / 500k tokens / $5 / 20 min.
# BASILISK_MAX_TURNS=40
# BASILISK_MAX_TOKENS=500000
# BASILISK_MAX_COST_CENTS=500
# BASILISK_MAX_DURATION_SECS=1200

# Session DB path. Defaults to ~/.basilisk/sessions.db.
# BASILISK_SESSION_DB=/custom/path/sessions.db

# Path to an override system prompt (otherwise uses the embedded
# recon_v2.md for recon, vuln_v3.md for --vuln). Point at a working
# copy during prompt iteration without a full rebuild.
# BASILISK_SYSTEM_PROMPT=crates/agent/src/prompts/recon_v2.md

# Silence the live progress stream on stderr. Set to "true"/"1" to
# enable; leave unset to see streaming output.
# BASILISK_NO_STREAM=true

# Etherscan (and compatible explorer) API key — used to pull verified
# source, ABIs, and bytecode for on-chain targets.
# ETHERSCAN_API_KEY=

# Alchemy API key — used for RPC access when forking/simulating mainnet and
# L2s during exploit reproduction. The exec backend (basilisk-exec) constructs
# `https://eth-mainnet.g.alchemy.com/v2/<key>` and similar templates for opt /
# arb / polygon / base. BNB has no Alchemy template — use RPC_URL_BNB.
# ALCHEMY_API_KEY=

# --- Forking / simulation RPC (used by Set 9's vulnerability reasoning) ---
#
# When running `basilisk recon --vuln` or `basilisk bench`, the exec backend spawns
# anvil subprocesses forked from one of these URLs. Resolution priority:
#   1. MAINNET_RPC_URL (ethereum only)
#   2. RPC_URL_<CHAIN> (e.g. RPC_URL_OPTIMISM)
#   3. ALCHEMY_API_KEY (constructed per-chain)
#
# Foundry (forge / anvil) must be installed on $PATH:
#   curl -L https://foundry.paradigm.xyz | bash && foundryup

# Explicit override for the ethereum upstream — wins over both ALCHEMY_API_KEY
# and RPC_URL_ETHEREUM. Useful for archive-RPC providers other than Alchemy.
# MAINNET_RPC_URL=https://eth.llamarpc.com

# Per-chain RPC overrides. Capitalisation must be uppercase canonical names.
# RPC_URL_OPTIMISM=https://opt-mainnet.example.com/...
# RPC_URL_ARBITRUM=https://arb-mainnet.example.com/...
# RPC_URL_POLYGON=https://polygon-mainnet.example.com/...
# RPC_URL_BASE=https://base-mainnet.example.com/...
# RPC_URL_BNB=https://bsc-dataseed.bnbchain.org

# GitHub personal access token — used to clone private repos and raise the
# API rate limit when reconnoitering multi-repo targets. `public_repo` scope
# is sufficient for public audits.
# GITHUB_TOKEN=

# Default log level when RUST_LOG is not set. Accepts any tracing filter
# directive (e.g. "info", "debug", "basilisk=debug,warn").
# LOG_LEVEL=info

# --- Embeddings (used by `basilisk knowledge ingest` and the agent's KB tools) ---
#
# Basilisk auto-selects the first configured provider in order:
#   Voyage → OpenAI → Ollama
# Set EMBEDDINGS_PROVIDER to pin a specific one.

# Voyage AI — primary embedding provider (voyage-code-3, 1024 dims).
# Best quality for Solidity / security text. Get a key at voyageai.com.
# VOYAGE_API_KEY=pa-...

# OpenAI embeddings — fallback when VOYAGE_API_KEY is absent.
# Reuses OPENAI_API_KEY (already set above if you're using the OpenAI LLM).

# Local Ollama endpoint — fully offline embeddings (nomic-embed-text, 768 dims).
# OLLAMA_HOST=http://localhost:11434

# Explicit provider override. One of: voyage | openai | ollama | openrouter
# EMBEDDINGS_PROVIDER=voyage

# OpenRouter embedding model + dimensionality (only needed when
# EMBEDDINGS_PROVIDER=openrouter).
# OPENROUTER_EMBEDDINGS_MODEL=mistralai/mistral-embed
# OPENROUTER_EMBEDDINGS_DIM=1024

# Optional rate cap for Voyage ingestion (tokens per minute).
# Useful on the free tier. Leave unset to run at full speed.
# VOYAGE_TOKEN_RATE_PER_MINUTE=1000000

# --- On-chain timeouts --------------------------------------------------

# Timeout for on-chain resolution requests (RPC + explorer calls), in seconds.
# ONCHAIN_TIMEOUT_SECS=60
