# Basilisk environment configuration.
# Copy to `.env` at the workspace root and fill in the keys you need.
# Every key is optional during Phase 1 — features that require a specific
# key will error at the point of use, not at startup.

# Anthropic API key — default LLM provider for the agent loop
# (`audit recon <target> --agent`).
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key — used when running with `--provider openrouter`.
# Unlocks Claude, GPT, Gemini, Llama, and every other model OpenRouter
# proxies, all via the same key.
# OPENROUTER_API_KEY=sk-or-...

# OpenAI API key — used when running with `--provider openai`. Also
# used as the fallback key for `--provider openai-compat` when no
# `--llm-api-key-env` override is given.
# OPENAI_API_KEY=sk-...

# Etherscan (and compatible explorer) API key — used to pull verified
# source, ABIs, and bytecode for on-chain targets.
# ETHERSCAN_API_KEY=

# Alchemy API key — used for RPC access when forking/simulating mainnet and
# L2s during exploit reproduction.
# ALCHEMY_API_KEY=

# GitHub personal access token — used to clone private repos and raise the
# API rate limit when reconnoitering multi-repo targets. `public_repo` scope
# is sufficient for public audits.
# GITHUB_TOKEN=

# Default log level when RUST_LOG is not set. Accepts any tracing filter
# directive (e.g. "info", "debug", "basilisk=debug,warn").
# LOG_LEVEL=info
